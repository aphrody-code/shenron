# ============================================================
# OBLIGATOIRE
# ============================================================
DISCORD_TOKEN=ton-token-ici

# Guild où les slash commands sont enregistrées.
# Guild test  : 1497167233280118896
# Guild prod  : 934894610545770506
GUILD_ID=1497167233280118896

# Admin du serveur — bénéficie des overrides statiques (/gay=0, /raciste=101)
# et du garde OwnerOnly.
OWNER_ID=853295213473038376

# ============================================================
# OPTIONNEL
# ============================================================

# Dev du bot — également accepté par le garde OwnerOnly pour les commandes
# techniques. Laisser vide si inutilisé.
BOT_DEV_ID=281114294152724491

# Identité de l'application Discord (portail développeur)
# Utilisé pour générer le lien d'invitation et par les APIs applicatives.
# Non requis au runtime (discord.js se connecte uniquement via DISCORD_TOKEN).
APPLICATION_ID=1497194276025663680

# Clé publique de l'app — NÉCESSAIRE UNIQUEMENT pour vérifier la signature des
# webhooks d'interactions HTTP. Ce bot utilise le Gateway WebSocket, donc cette
# clé est informative. Ne JAMAIS l'utiliser à la place du token.
DISCORD_PUBLIC_KEY=4f39abaef492cc832d131bce2fcc604962441e43cb05f8e3da3704656c30d0cc

# Base de données (SQLite, chemin relatif)
DATABASE_PATH=./data/bot.db

# Salons de logs — un par catégorie.
# Laisse vide pour désactiver la catégorie (le bot n'enverra juste rien).
LOG_MESSAGE_CHANNEL_ID=
LOG_SANCTION_CHANNEL_ID=
LOG_ECONOMY_CHANNEL_ID=
LOG_JOIN_LEAVE_CHANNEL_ID=
LOG_LEVEL_ROLE_CHANNEL_ID=
LOG_TICKET_CHANNEL_ID=

# Salon où les modérateurs reçoivent les notifs d'ouverture de ticket
MOD_NOTIFY_CHANNEL_ID=

# Salon des annonces générales (level-up, quête quotidienne)
ANNOUNCE_CHANNEL_ID=

# Salon dédié aux 🏆 accomplissements. Si vide → retombe sur ANNOUNCE_CHANNEL_ID.
# Permet d'isoler les notifs de succès dans un canal cosmétique.
ACHIEVEMENT_CHANNEL_ID=

# Salon où les slash commands user (jeux, fun, profil) sont autorisées.
# Les autres salons → message d'erreur si l'user tente de lancer une commande.
COMMANDS_CHANNEL_ID=

# Rôles
JAIL_ROLE_ID=              # Rôle appliqué par /jail (accès uniquement au salon ticket de déblocage)
URL_IN_BIO_ROLE_ID=        # Rôle auto-attribué si l'URL du serveur est détectée dans le statut

# Catégories / hubs
TICKET_CATEGORY_ID=        # Catégorie sous laquelle les tickets sont créés
VOCAL_TEMPO_HUB_ID=        # Salon vocal "hub" — le rejoindre crée un vocal perso

# Invitation du serveur (utilisée pour la whitelist anti-lien + détection URL en bio)
SERVER_INVITE_URL=https://discord.gg/2JayQtyN

# ============================================================
# /translate (OCR + traduction, 100 % FOSS)
# ============================================================
# Stack auto-installable via : sudo bash scripts/setup-translate.sh
#   - Tesseract OCR (Apache 2.0) — apt install tesseract-ocr-{fra,eng,jpn,...}
#   - LibreTranslate (AGPL-3.0)  — Docker container 127.0.0.1:5000

# Endpoint LibreTranslate. Défaut http://127.0.0.1:5000 (self-host Docker).
# Pour utiliser le service public : LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_URL=

# Optionnel — clé API requise par certains endpoints publics (libretranslate.com).
# Inutile pour un self-host Docker.
LIBRETRANSLATE_API_KEY=

# Logging interne du bot
LOG_LEVEL=info             # trace | debug | info | warn | error | fatal
NODE_ENV=development       # development | production | test
