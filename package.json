{
	"name": "shenron",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"build": "bun build src/index.ts --target=bun --outfile=dist/index.js",
		"compile": "bun build src/index.ts --compile --minify --sourcemap --outfile=dist/shenron",
		"type-check": "bunx tsc --noEmit",
		"gen:entries": "bun scripts/gen-entries.ts",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bun src/db/migrate.ts",
		"db:seed-wiki": "bun src/db/seed-wiki.ts",
		"db:seed-triggers": "bun src/db/seed-triggers.ts",
		"db:seed-all": "bun src/db/seed-wiki.ts && bun src/db/seed-triggers.ts",
		"db:studio": "bunx drizzle-kit studio",
		"db:push": "bunx drizzle-kit push"
	},
	"dependencies": {
		"@napi-rs/canvas": "^0.1.99",
		"@rpbey/di": "^0.1.0",
		"@rpbey/discordx": "^0.1.0",
		"@rpbey/importer": "^0.1.0",
		"@rpbey/pagination": "^0.1.0",
		"dayjs": "^1.11.20",
		"discord.js": "^14.26.3",
		"drizzle-orm": "^0.44.1",
		"pino": "^10.1.0",
		"pino-pretty": "^13.0.0",
		"reflect-metadata": "^0.2.2",
		"tsyringe": "^4.10.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"drizzle-kit": "^0.31.0",
		"typescript": "^5.9.3"
	},
	"engines": {
		"bun": ">=1.2.0"
	}
}
