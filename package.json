{
  "name": "shenron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun run dashboard:css && bun build src/index.ts --target=bun --outdir=dist",
    "dashboard:css": "bunx @tailwindcss/cli --input src/dashboard/styles.css --output src/dashboard/styles.compiled.css --minify",
    "dashboard:watch": "bunx @tailwindcss/cli --input src/dashboard/styles.css --output src/dashboard/styles.compiled.css --watch",
    "compile": "bun build src/index.ts --compile --minify --sourcemap --outfile=dist/shenron",
    "type-check": "bunx tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "deploy": "bun scripts/deploy.ts",
    "test": "bun test tests/",
    "ids": "bun scripts/discover-ids.ts",
    "watch-logs": "bun scripts/log-watcher.ts",
    "bg:fetch": "bun scripts/fetch-backgrounds.ts --download",
    "bg:optimize": "bun scripts/optimize-backgrounds.ts",
    "bg:all": "bun scripts/fetch-backgrounds.ts --download && bun scripts/optimize-backgrounds.ts",
    "gen:entries": "bun scripts/gen-entries.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed-wiki": "bun src/db/seed-wiki.ts",
    "db:seed-triggers": "bun src/db/seed-triggers.ts",
    "db:seed-levels": "bun src/db/seed-level-rewards.ts",
    "db:seed-all": "bun src/db/seed-wiki.ts && bun src/db/seed-triggers.ts && bun src/db/seed-level-rewards.ts",
    "db:studio": "bunx drizzle-kit studio",
    "db:push": "bunx drizzle-kit push"
  },
  "dependencies": {
    "@aphrody-code/canvas": "0.1.99-fork.4",
    "@rpbey/di": "workspace:*",
    "@rpbey/discordx": "workspace:*",
    "@rpbey/importer": "workspace:*",
    "@rpbey/pagination": "workspace:*",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "discord.js": "catalog:",
    "drizzle-orm": "^0.44.1",
    "lucide-react": "^1.11.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.5.0",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "drizzle-kit": "^0.31.0",
    "oxlint": "^1.61.0",
    "tailwindcss": "^4.2.4",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
